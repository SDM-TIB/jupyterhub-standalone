# JupyterHub standalone configuration

# JupyterHub API token for authentication
JUPYTERHUB_API_TOKEN=0141eb691d9b4e138900c5a83cfc191d

# JupyterHub base URL
JUPYTERHUB_BASE_URL=/ldmjupyter

# JupyterHub URL
JUPYTERNOTEBOOK_URL=http://localhost:8000/ldmjupyter/

# Path to notebook storage
# STORAGE_PATH=/var/lib/jupyterhub/notebooks
STORAGE_PATH=/notebooks

# API URL for JupyterHub services
API_JUPYTERHUB=http://jupyterhub:6000

# Docker network name
NETWORK=jupyterhub_network

# Timeout for JupyterHub sessions (timeout in seconds)
JUPYTERHUB_TIMEOUT=90

# How often the idle culler checks for inactive servers (in seconds)
# Maps to --cull-every. Set to 0 to use the culler's default interval.
# Recommended: lower than JUPYTERHUB_TIMEOUT to ensure timely culling
JUPYTERHUB_CULLER_POLL_INTERVAL=10

# Maximum lifetime of a server regardless of activity (in seconds)
# Ensures containers are always culled even if kernels keep them "active"
# Set to 0 to disable. Recommended: a multiple of JUPYTERHUB_TIMEOUT
JUPYTERHUB_CULLER_MAX_AGE=120

# The maximum number of concurrent users allowed
JUPYTERHUB_USER=3

# The percentage of CPU core allocated to each container
JUPYTERHUB_PERCENTAGE_CPU=50

# Limit on the amount of memory that the container can use
JUPYTERHUB_MEMORY_LIMIT=1G

# Limit on disk space for each JupyterHub container
JUPYTERHUB_STORAGE_LIMIT=1G
